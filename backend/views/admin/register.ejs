<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Admin Register' }) %>
</head>
<body>
  <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card p-4" style="width: 380px;">
      <div class="text-center mb-3">
        <i class="bi bi-calendar-check" style="font-size: 2rem; color: #0d6efd;"></i>
        <h4 class="mt-2 mb-0">Create Admin Account</h4>
        <p class="text-muted small">For placement cell / TPO coordinators</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger py-2 small"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/register">
        <div class="mb-3">
          <label class="form-label small">Full name</label>
          <input type="text" name="name" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label small">Email</label>
          <input type="email" name="email" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label small">Password</label>
          <input type="password" name="password" class="form-control" minlength="6" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Create Account</button>
      </form>

      <p class="text-center text-muted small mt-3 mb-0">
        Already have an account? <a href="/admin/login">Log in</a>
      </p>
    </div>
  </div>
</body>
</html>
